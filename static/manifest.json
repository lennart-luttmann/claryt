{
    "manifest_version": 3,
    "name": "ClarYT",
    "version": "0.1.0",
    "description": "An extension to disable certain YouTube UI elements or adjust the UX to your liking.",
    "permissions": ["tabs", "activeTab", "storage"],
    "action": {
        "default_popup": "dashboard/index.html"
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": ["*://*.youtube.com/*"],
            "js": ["feed_watchdog.js", "comment_watchdog.js"],
            "run_at": "document_idle"
        }
    ]
}
