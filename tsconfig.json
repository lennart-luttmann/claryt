{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ES2020",
        "resolveJsonModule": true,
        "lib": ["ES2020", "dom"],
        "moduleResolution": "bundler",
        "strict": true,
        "skipLibCheck": true,
        "types": ["chrome"],
        "paths": {
            "$/*": ["./src/*"]
        }
    },
    "include": ["src"]
}
